{
  "name": "@localinference/utils",
  "version": "1.0.0",
  "description": "Local Inference internal utils package to avoid boilerplate across codebases.",
  "keywords": [
    "localinference",
    "onnx",
    "tokenizer",
    "sentencepiece",
    "inference",
    "browser",
    "esm",
    "commonjs",
    "typescript"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localinference/utils.git"
  },
  "bugs": {
    "url": "https://github.com/localinference/utils/issues"
  },
  "homepage": "https://github.com/localinference/utils#readme",
  "scripts": {
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "build": "tsup",
    "test:coverage": "npm run build && node test/run-coverage.mjs",
    "test:e2e": "npm run build && node test/e2e/run.mjs",
    "test": "npm run test:coverage && node test/e2e/run.mjs",
    "bench": "npm run build && node benchmark/bench.js",
    "prepare": "husky",
    "prepublishOnly": "npm run test && npm run bench"
  },
  "c8": {
    "all": true,
    "include": [
      "dist/**/*.js"
    ],
    "exclude": [
      "dist/**/*.d.ts",
      "test/**",
      "benchmark/**",
      "playwright.config.ts"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "edge-runtime": "^4.0.1",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@sctg/sentencepiece-js": "^1.3.3",
    "@sovereignbase/bytecodec": "^1.3.3",
    "onnxruntime-web": "^1.24.3"
  }
}
